{
  "name": "backend-faworki",
  "version": "1.0.0",
  "description": "Backend API para FaWorKi - Aplicación de trabajo freelance",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node start-production.js",
    "start:dev": "node server.js",
    "dev": "node scripts/pre-flight-check.js && nodemon server.js",
