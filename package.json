    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^7.1.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.9.0",
    "mongodb": "^7.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
